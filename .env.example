# GitLab 配置
GITLAB_URL=https://git.dp.tech/
GITLAB_PROJECT_ID=993
GITLAB_TOKEN=your-gitlab-token

# Git 配置
REPO_URL=git@git.dp.tech:group/project.git
REPO_LOCAL_PATH=/data/blog-repo
SSH_KEY_PATH=/app/.ssh/id_rsa
TARGET_BRANCH=test

# SSH known_hosts（可选，不设置则使用系统默认 ~/.ssh/known_hosts）
# SSH_KNOWN_HOSTS_PATH=/app/.ssh/known_hosts

# 应用配置
HOST=0.0.0.0
PORT=8000

# 类别目录（JSON数组格式，可选）
# CATEGORY_FOLDERS=["30-day-sprint","dev-diaries","tutorials"]
